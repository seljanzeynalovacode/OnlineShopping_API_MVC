@model Online_Shop_API.BLL.Dtos.CustomerDto

@{
    ViewData["Title"] = "Edit Customer";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
       <h1 class="mb-4">Edit Customer</h1>

    <form asp-action="Edit" method="post" class="needs-validation" novalidate>
 <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

      <input type="hidden" asp-for="Id" />

        <div class="mb-3">
   <label asp-for="Name" class="form-label">First Name</label>
   <input asp-for="Name" class="form-control" placeholder="Enter first name" required />
   <span asp-validation-for="Name" class="text-danger"></span>
     </div>

          <div class="mb-3">
         <label asp-for="Surname" class="form-label">Last Name</label>
           <input asp-for="Surname" class="form-control" placeholder="Enter last name" required />
          <span asp-validation-for="Surname" class="text-danger"></span>
        </div>

        <div class="mb-3">
          <label asp-for="Email" class="form-label">Email</label>
     <input asp-for="Email" type="email" class="form-control" placeholder="Enter email address" required />
            <span asp-validation-for="Email" class="text-danger"></span>
          </div>

       <div class="mb-3">
        <label asp-for="Phone" class="form-label">Phone Number</label>
      <input asp-for="Phone" type="tel" class="form-control" placeholder="Enter phone number" required />
          <span asp-validation-for="Phone" class="text-danger"></span>
    </div>

                <div class="d-grid gap-2 d-sm-flex justify-content-sm-end mt-4">
         <button type="submit" class="btn btn-primary">Save Changes</button>
  <a asp-action="Index" class="btn btn-secondary">Cancel</a>
  </div>
  </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

