@model Online_Shop_API.BLL.Dtos.CustomerDto

@{
    ViewData["Title"] = "Customer Details";
}

<div class="container mt-5">
    <div class="row justify-content-center">
    <div class="col-md-8">
      <h1 class="mb-4">Customer Details</h1>

   <div class="card mb-4">
   <div class="card-header bg-primary text-white">
              <h5 class="mb-0">Customer Information</h5>
        </div>
       <div class="card-body">
          <dl class="row">
      <dt class="col-sm-3">ID</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.Id)</dd>

      <dt class="col-sm-3">First Name</dt>
       <dd class="col-sm-9">@Html.DisplayFor(model => model.Name)</dd>

            <dt class="col-sm-3">Last Name</dt>
<dd class="col-sm-9">@Html.DisplayFor(model => model.Surname)</dd>

    <dt class="col-sm-3">Email</dt>
 <dd class="col-sm-9">
      <a href="mailto:@Model.Email">@Html.DisplayFor(model => model.Email)</a>
               </dd>

          <dt class="col-sm-3">Phone</dt>
           <dd class="col-sm-9">
            <a href="tel:@Model.Phone">@Html.DisplayFor(model => model.Phone)</a>
   </dd>
 </dl>
           </div>
   </div>

            <div class="d-grid gap-2 d-sm-flex justify-content-sm-end">
       <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
      <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
      </div>
    </div>
</div>

