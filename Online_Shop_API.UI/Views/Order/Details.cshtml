@model Online_Shop_API.BLL.Dtos.OrderDto
@using Online_Shop_API.DAL.Enums

@{
    ViewData["Title"] = "Order Details";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
          <h1 class="mb-4">Order Details</h1>

          <div class="card mb-4">
    <div class="card-header bg-primary text-white">
       <h5 class="mb-0">Order Information</h5>
            </div>
        <div class="card-body">
         <dl class="row">
    <dt class="col-sm-3">ID</dt>
         <dd class="col-sm-9">@Html.DisplayFor(model => model.Id)</dd>

          <dt class="col-sm-3">Order Date</dt>
   <dd class="col-sm-9">@Html.DisplayFor(model => model.OrderDate)</dd>

      <dt class="col-sm-3">Customer ID</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.CustomerId)</dd>

             <dt class="col-sm-3">Total Amount</dt>
      <dd class="col-sm-9">
  <span class="badge bg-success">$@Html.DisplayFor(model => model.TotalAmount)</span>
          </dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">
   @{
     var statusColor = Model.Status == Status.Pending ? "warning" :
      Model.Status == Status.Completed ? "success" : "danger";
        }
         <span class="badge bg-@statusColor">@Model.Status.ToString()</span>
     </dd>
       </dl>
     </div>
          </div>

 <div class="d-grid gap-2 d-sm-flex justify-content-sm-end">
       <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
   <a asp-action="Index" class="btn btn-secondary">Back to List</a>
          </div>
    </div>
    </div>
</div>

