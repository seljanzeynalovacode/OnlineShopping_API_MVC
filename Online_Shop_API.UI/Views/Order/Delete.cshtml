@model Online_Shop_API.BLL.Dtos.OrderDto
@using Online_Shop_API.DAL.Enums

@{
    ViewData["Title"] = "Delete Order";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1 class="mb-4 text-danger">Delete Order</h1>

            <div class="alert alert-warning" role="alert">
                <h4 class="alert-heading">Warning!</h4>
                <p>Are you sure you want to delete this order? This action cannot be undone.</p>
            </div>

            <div class="card mb-4">
                <div class="card-body">
                    <h5 class="card-title">Order Information</h5>
                    <dl class="row">
                        <dt class="col-sm-3">ID</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Id)</dd>

                        <dt class="col-sm-3">Order Date</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.OrderDate)</dd>

                        <dt class="col-sm-3">Customer ID</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.CustomerId)</dd>

                        <dt class="col-sm-3">Total Amount</dt>
                        <dd class="col-sm-9">
                            <span class="badge bg-success">$@Html.DisplayFor(model => model.TotalAmount)</span>
                        </dd>

                        <dt class="col-sm-3">Status</dt>
                        <dd class="col-sm-9">
                            @{
                                var statusColor = Model.Status == Status.Pending ? "warning" :
                                Model.Status == Status.Completed ? "success" : "danger";
                            }
                            <span class="badge bg-@statusColor">@Model.Status.ToString()</span>
                        </dd>
                    </dl>
                </div>
            </div>

            <form asp-action="Delete" method="post" class="d-inline">
                <input type="hidden" asp-for="Id" />
                <div class="d-grid gap-2 d-sm-flex justify-content-sm-end">
                    <button type="submit" class="btn btn-danger">Confirm Delete</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

