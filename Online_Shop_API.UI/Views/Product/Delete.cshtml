@model Online_Shop_API.BLL.Dtos.ProductDto

@{
    ViewData["Title"] = "Delete Product";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1 class="mb-4 text-danger">Delete Product</h1>

  <div class="alert alert-warning" role="alert">
          <h4 class="alert-heading">Warning!</h4>
         <p>Are you sure you want to delete this product? This action cannot be undone.</p>
   </div>

   <div class="card mb-4">
                <div class="card-body">
      <h5 class="card-title">Product Information</h5>
             <dl class="row">
   <dt class="col-sm-3">ID</dt>
   <dd class="col-sm-9">@Html.DisplayFor(model => model.Id)</dd>

      <dt class="col-sm-3">Product Name</dt>
     <dd class="col-sm-9">@Html.DisplayFor(model => model.Name)</dd>

<dt class="col-sm-3">Price</dt>
            <dd class="col-sm-9">$@Html.DisplayFor(model => model.Price)</dd>

     <dt class="col-sm-3">Discount</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Discount)%</dd>

  <dt class="col-sm-3">Stock Quantity</dt>
   <dd class="col-sm-9">@Html.DisplayFor(model => model.StockQuantity)</dd>

     <dt class="col-sm-3">Category ID</dt>
          <dd class="col-sm-9">@Html.DisplayFor(model => model.CategoryId)</dd>
         </dl>
    </div>
    </div>

            <form asp-action="Delete" method="post" class="d-inline">
                <input type="hidden" asp-for="Id" />
  <div class="d-grid gap-2 d-sm-flex justify-content-sm-end">
    <button type="submit" class="btn btn-danger">Confirm Delete</button>
      <a asp-action="Index" class="btn btn-secondary">Cancel</a>
      </div>
            </form>
        </div>
    </div>
</div>

