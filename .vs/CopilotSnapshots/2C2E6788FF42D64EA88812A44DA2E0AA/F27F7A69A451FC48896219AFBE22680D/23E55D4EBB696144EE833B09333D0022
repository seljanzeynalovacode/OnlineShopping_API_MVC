@model Online_Shop_API.BLL.Dtos.CategoryDto

@{
    ViewData["Title"] = "Create Category";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
         <h1 class="mb-4">Create New Category</h1>

            <form asp-action="Create" method="post" class="needs-validation" novalidate>
         <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="mb-3">
             <label asp-for="Name" class="form-label">Category Name</label>
          <input asp-for="Name" class="form-control" placeholder="Enter category name" required />
          <span asp-validation-for="Name" class="text-danger"></span>
      </div>

        <div class="mb-3">
        <label asp-for="Description" class="form-label">Description</label>
      <textarea asp-for="Description" class="form-control" rows="5" placeholder="Enter category description" required></textarea>
           <span asp-validation-for="Description" class="text-danger"></span>
      </div>

                <div class="d-grid gap-2 d-sm-flex justify-content-sm-end mt-4">
                    <button type="submit" class="btn btn-primary">Create Category</button>
         <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

