@model Online_Shop_API.BLL.Dtos.ProductDto

@{
    ViewData["Title"] = "Product Details";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1 class="mb-4">Product Details</h1>

            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Product Information</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">ID</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Id)</dd>

                        <dt class="col-sm-3">Product Name</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Name)</dd>

                        <dt class="col-sm-3">Price</dt>
                        <dd class="col-sm-9">
                            <span class="badge bg-success">$@Html.DisplayFor(model => model.Price)</span>
                        </dd>

                        <dt class="col-sm-3">Discount</dt>
                        <dd class="col-sm-9">
                            @if (Model.Discount > 0)
                            {
                            <span class="badge bg-warning text-dark">@Html.DisplayFor(model => model.Discount)%</span>
                            }
                            else
                            {
                            <span class="badge bg-secondary">No Discount</span>
                            }
                        </dd>

                        <dt class="col-sm-3">Stock Quantity</dt>
                        <dd class="col-sm-9">
                            @if (Model.StockQuantity > 0)
                            {
                            <span class="badge bg-info">@Html.DisplayFor(model => model.StockQuantity) in stock</span>
                            }
                            else
                            {
                            <span class="badge bg-danger">Out of Stock</span>
                            }
                        </dd>

                        <dt class="col-sm-3">Category ID</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.CategoryId)</dd>
                    </dl>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0">Calculated Information</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">Discounted Price</dt>
                        <dd class="col-sm-9">
                            @{
                                decimal discountedPrice = Model.Price - (Model.Price * Model.Discount / 100);
                            }
                            <span class="text-success">$@discountedPrice.ToString("F2")</span>
                        </dd>

                        <dt class="col-sm-3">Total Value</dt>
                        <dd class="col-sm-9">
                            <span class="text-primary">$@(Model.Price * Model.StockQuantity).ToString("F2")</span>
                        </dd>
                    </dl>
                </div>
            </div>

            <div class="d-grid gap-2 d-sm-flex justify-content-sm-end">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </div>
    </div>
</div>

