@model IEnumerable<Online_Shop_API.BLL.Dtos.OrderDetailDto>

@{
    ViewData["Title"] = "Order Details";
}

<div class="container-fluid mt-5">
  <div class="row mb-4">
        <div class="col-md-6">
            <h1 class="mb-0">
         <i class="bi bi-list-check"></i> Order Details Management
            </h1>
      </div>
   <div class="col-md-6 text-end">
            <a asp-action="Create" class="btn btn-success btn-lg">
     <i class="bi bi-plus-circle"></i> Create New Order Detail
   </a>
      </div>
    </div>

    @if (Model.Count() == 0)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
  <strong>No order details found!</strong> Start by creating a new order detail.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    else
    {
      <div class="card shadow-sm">
            <div class="table-responsive">
 <table class="table table-hover mb-0">
     <thead class="table-dark">
        <tr>
                    <th class="text-center" style="width: 8%;">
     <i class="bi bi-hash"></i> ID
       </th>
       <th class="text-center" style="width: 12%;">
       <i class="bi bi-receipt"></i> Order ID
</th>
    <th class="text-center" style="width: 12%;">
       <i class="bi bi-box"></i> Product ID
          </th>
  <th class="text-center" style="width: 10%;">
              <i class="bi bi-stack"></i> Quantity
</th>
                     <th class="text-center" style="width: 12%;">
      <i class="bi bi-currency-dollar"></i> Price
            </th>
             <th class="text-center" style="width: 12%;
">
 <i class="bi bi-calculator"></i> Total
       </th>
     <th class="text-center" style="width: 34%;">
        <i class="bi bi-gear"></i> Actions
      </th>
      </tr>
        </thead>
                  <tbody>
     @foreach (var item in Model)
      {
             decimal total = item.Quantity * item.Price;
              <tr>
        <td class="text-center">
  <span class="badge bg-primary">@Html.DisplayFor(modelItem => item.Id)</span>
   </td>
           <td class="text-center">
         <span class="badge bg-info">@Html.DisplayFor(modelItem => item.OrderId)</span>
      </td>
     <td class="text-center">
       <span class="badge bg-info">@Html.DisplayFor(modelItem => item.ProductId)</span>
         </td>
     <td class="text-center">
    <span class="badge bg-secondary">@Html.DisplayFor(modelItem => item.Quantity)</span>
 </td>
 <td class="text-center">
          <span class="badge bg-success">$@Html.DisplayFor(modelItem => item.Price)</span>
  </td>
    <td class="text-center">
              <span class="badge bg-primary fw-bold">$@total.ToString("F2")</span>
           </td>
     <td class="text-center">
          <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">
  <i class="bi bi-eye"></i> View
           </a>
      <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
   <i class="bi bi-pencil"></i> Edit
       </a>
             <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
            <i class="bi bi-trash"></i> Delete
            </a>
           </td>
     </tr>
          }
 </tbody>
          </table>
            </div>
            <div class="card-footer bg-light">
       <small class="text-muted">
   <i class="bi bi-info-circle"></i> Total Records: <strong>@Model.Count()</strong>
              </small>
    </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Bootstrap tooltips initialization
      document.addEventListener('DOMContentLoaded', function () {
   var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
          var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
      return new bootstrap.Tooltip(tooltipTriggerEl);
 });
    });
    </script>
}
